post_install() {
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/mdcal.conf
  cat <<'EOF'
mdcal: deck storage provisioned at /var/lib/mdcal (owned by will).

Import a calendar into a deck with:
  mdcal-import --source <name> --ics <path.ics> --deck /var/lib/mdcal/<name>

Preview the card shape first without writing:
  mdcal-import --source <name> --ics <path.ics> --dry-run --limit 5
EOF
}

post_upgrade() {
  post_install
}
